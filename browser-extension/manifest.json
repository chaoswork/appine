{
  "manifest_version": 3,
  "name": "Appine Plugins Loader",
  "version": "1.0",
  "description": "原生 ES Module 方式加载插件，无视 CSP",
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "plugins/*/index.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
